<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080" width="1920" height="1080">
  <defs>
    <!-- Deep SaaS Background Base -->
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#08111F" />
      <stop offset="50%" stop-color="#050B14" />
      <stop offset="100%" stop-color="#02050A" />
    </linearGradient>

    <!-- Glowing Light Orbs Gradients -->
    <radialGradient id="glowPrimary" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#38BDF8" stop-opacity="0.45" />
      <stop offset="40%" stop-color="#2563EB" stop-opacity="0.25" />
      <stop offset="70%" stop-color="#1D4ED8" stop-opacity="0.08" />
      <stop offset="100%" stop-color="#08111F" stop-opacity="0" />
    </radialGradient>

    <radialGradient id="glowSecondary" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#60A5FA" stop-opacity="0.35" />
      <stop offset="50%" stop-color="#3B82F6" stop-opacity="0.15" />
      <stop offset="100%" stop-color="#08111F" stop-opacity="0" />
    </radialGradient>

    <radialGradient id="glowCyan" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#2DD4BF" stop-opacity="0.25" />
      <stop offset="60%" stop-color="#0EA5E9" stop-opacity="0.08" />
      <stop offset="100%" stop-color="#08111F" stop-opacity="0" />
    </radialGradient>

    <!-- Heavy Gaussian Blur Filters for Soft Atmospheric Lighting -->
    <filter id="heavyBlur" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="120" />
    </filter>

    <filter id="softBlur" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="60" />
    </filter>

    <!-- Edge Fade / Transparent Safety Vignette Mask -->
    <radialGradient id="edgeFade" cx="50%" cy="50%" r="65%">
      <stop offset="40%" stop-color="#FFFFFF" stop-opacity="1" />
      <stop offset="85%" stop-color="#FFFFFF" stop-opacity="0.4" />
      <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0" />
    </radialGradient>
    <mask id="vignetteMask">
      <rect width="1920" height="1080" fill="url(#edgeFade)" />
    </mask>
  </defs>

  <!-- Deep Base Canvas -->
  <rect width="1920" height="1080" fill="url(#bgGrad)" />

  <!-- Masked Layer for Soft Edge Transparency & Seamless Integration -->
  <g mask="url(#vignetteMask)">
    <!-- Ambient Base Light Sweep -->
    <ellipse cx="960" cy="300" rx="900" ry="450" fill="url(#glowPrimary)" filter="url(#heavyBlur)" />

    <!-- Secondary Accent Light Orbs (Floating Digital Atmosphere) -->
    <circle cx="450" cy="700" r="500" fill="url(#glowSecondary)" filter="url(#heavyBlur)" />
    <circle cx="1500" cy="650" r="550" fill="url(#glowCyan)" filter="url(#heavyBlur)" />
    
    <!-- Central Core Intensity Beam -->
    <circle cx="960" cy="450" r="350" fill="url(#glowPrimary)" filter="url(#softBlur)" opacity="0.8" />
    <circle cx="960" cy="400" r="180" fill="#FFFFFF" opacity="0.12" filter="url(#softBlur)" />

    <!-- Subtle Digital Light Streaks / Ambient Waves -->
    <path d="M-100 200 C400 600, 1500 100, 2020 500" stroke="url(#glowPrimary)" stroke-width="2" fill="none" opacity="0.3" filter="url(#softBlur)" />
    <path d="M-100 800 C600 300, 1300 900, 2020 400" stroke="url(#glowCyan)" stroke-width="1.5" fill="none" opacity="0.25" filter="url(#softBlur)" />
  </g>
</svg>
